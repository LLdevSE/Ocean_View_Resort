<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Ocean View Resort - Hotel Reservation System</display-name>

    <!-- Welcome file -->
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session Timeout: 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Auth Filter for Admin pages -->
    <filter>
        <filter-name>AdminAuthFilter</filter-name>
        <filter-class>com.oceanview.filter.AdminAuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- Auth Filter for Staff pages -->
    <filter>
        <filter-name>StaffAuthFilter</filter-name>
        <filter-class>com.oceanview.filter.StaffAuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>StaffAuthFilter</filter-name>
        <url-pattern>/staff/*</url-pattern>
    </filter-mapping>

    <!-- Login Servlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.oceanview.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Logout Servlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.oceanview.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Admin - Reservation Servlet -->
    <servlet>
        <servlet-name>AdminReservationServlet</servlet-name>
        <servlet-class>com.oceanview.servlet.admin.ReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminReservationServlet</servlet-name>
        <url-pattern>/admin/reservations</url-pattern>
    </servlet-mapping>

    <!-- Admin - Staff Servlet -->
    <servlet>
        <servlet-name>AdminStaffServlet</servlet-name>
        <servlet-class>com.oceanview.servlet.admin.StaffServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminStaffServlet</servlet-name>
        <url-pattern>/admin/staff</url-pattern>
    </servlet-mapping>

    <!-- Admin - Billing Servlet -->
    <servlet>
        <servlet-name>AdminBillingServlet</servlet-name>
        <servlet-class>com.oceanview.servlet.admin.BillingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminBillingServlet</servlet-name>
        <url-pattern>/admin/billing</url-pattern>
    </servlet-mapping>

    <!-- Staff - Reservation Servlet -->
    <servlet>
        <servlet-name>StaffReservationServlet</servlet-name>
        <servlet-class>com.oceanview.servlet.staff.StaffReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StaffReservationServlet</servlet-name>
        <url-pattern>/staff/reservations</url-pattern>
    </servlet-mapping>

    <!-- Staff - Profile Servlet -->
    <servlet>
        <servlet-name>StaffProfileServlet</servlet-name>
        <servlet-class>com.oceanview.servlet.staff.ProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StaffProfileServlet</servlet-name>
        <url-pattern>/staff/profile</url-pattern>
    </servlet-mapping>

</web-app>
